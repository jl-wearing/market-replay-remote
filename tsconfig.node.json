{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node", "vitest/globals"],
    "noEmit": true,
    "paths": {
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts",
    "src/preload/**/*.ts",
    "vitest.config.ts",
    "electron.vite.config.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist", "out", "release", "src/renderer"]
}
